#include <iostream>
#include <map>
#include <string>
#include <vector>

using namespace std;

class Person {
public:
    map <int, string> all_first_names;
    map <int, string> all_last_names;

    string GetName(int year, const map <int, string> list_names) {
        string name = "";
        for (const auto& i : list_names) {
            if (i.first <= year) {
                name = i.second;
            }
            else {
                break;
            }
        }
        return name;
    }

    void ChangeFirstName(int year, string first_name) {
        all_first_names[year] = first_name;
    }

    void ChangeLastName(int year, string last_name) {
        all_last_names[year] = last_name;
    }

    void GetFullName(int year) {
        string first = GetName(year, all_first_names);
        string last = GetName(year, all_last_names);

        if (first == "" && last == "") {
            cout << "Incognito" << endl;
        }
        else if (first == "") {
            cout << last + " with unknown first name" << endl;
        }
        else if (last == "") {
            cout << first + " with unknown last name" << endl;
        }
        else {
            cout << first + " " + last << endl;
        }
    }

    void GetFullNameWithHistory(int year) {
        string first_name = ResultNameWithHistory(year, all_first_names);
        string last_name = ResultNameWithHistory(year, all_last_names);

        if (first_name == "" && last_name == "") {
            cout << "Incognito" << endl;
        }
        else if (first_name == "") {
            cout << last_name + " with unknown first name" << endl;
        }
        else if (last_name == "") {
            cout << first_name + " with unknown last name" << endl;
        }
        else {
            cout << first_name + " " + last_name << endl;
        }
    }

    string ResultNameWithHistory(int year, map <int, string> names) {
        vector <string> history;
        string current;

        for (const auto& i : names) {
            if (i.first <= year) {
                if (i.second != current) {
                    current = i.second;
                    history.insert(history.begin(), current);
                }
            }
            else {
                break;
            }
        }

        if (history.empty()) {
            return "";
        }

        string result = history[0];
        if (history.size() > 1) {
            result += " (";
            for (size_t i = 1; i < history.size(); ++i) {
                result += history[i];
                if (i + 1 < history.size()) {
                    result += ", ";
                }
            }
            result += ")";
        }

        return result;
    }
};



int main() {
    Person person;

    person.ChangeFirstName(1965, "Maxim");
    person.ChangeLastName(1967, "Ivanov");
    for (int year : {1900, 1965, 1990}) {
        person.GetFullNameWithHistory(year);
    }
    cout << endl;
    person.ChangeFirstName(1970, "Andrey");
    for (int year : {1969, 1970}) {
        person.GetFullNameWithHistory(year);
    }
    cout << endl;
    person.ChangeLastName(1968, "Ivanov");
    for (int year : {1969, 1970}) {
        person.GetFullNameWithHistory(year);
    }
    cout << endl;
    person.ChangeFirstName(1980, "Petr");
    for (int year : {1978, 1981}) {
        person.GetFullNameWithHistory(year);
    }
}
