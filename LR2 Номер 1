#include <iostream>
#include <vector>
#include <string>
#include <algorithm>

using namespace std;

class SortedStrings {
public:
    vector <string> result;

    void addString(string str) {
        result.push_back(str);
        sort(begin(result), end(result));
    }

    void getStrings() {
        for (int i = 0; i < result.size(); i++) {
            cout << result[i] << " ";
        }
    }
};



