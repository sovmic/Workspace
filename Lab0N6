#include <iostream>
#include <string>
#include <vector>
#include <algorithm>

using namespace std;

/*
3
John Doe 15 5 1998
Alice Smith 12 6 2000
Bob Johnson 4 3 1998
*/

struct Student {
    string name, surname;
    int day, month, year;
};

bool SortByDate(Student a, Student b) {
    if (a.year == b.year) {
        if (a.month == b.month) {
            if (a.day == b.day) {
                if (a.surname == b.surname) {
                    return a.name < b.name;
                }
                return a.surname < b.surname;
            }
            return a.day < b.day;
        }
        return a.month < b.month;
    }
    return a.year < b.year;
}

bool SortByName(Student a, Student b) {
    if (a.surname == b.surname) {
        if (a.name == b.name) {
            if (a.year == b.year) {
                if (a.month == b.month) {
                    return a.day < b.day;
                }
                return a.month < b.month;
            }
            return a.year < b.year;
        }
        return a.name < b.name;
    }
    return a.surname < b.surname;
}

