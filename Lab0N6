    }

    cout << "Choose prefer sorting:\n1) By the lastname\n2) By the date.\n";
    cin >> sorting;

    if (sorting == "Surname" or sorting == "Lastname" or sorting == "surname" or sorting == "lastname") {
        sort(arr.begin(), arr.end(), SortByName);
    }
    else if (sorting == "date") {
        sort(arr.begin(), arr.end(), SortByDate);
    }
    else {
