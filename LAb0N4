#include <iostream>
#include <string>
#include <vector>

using namespace std;

//

vector <string> Split(string s, char delimiter) {
    vector <string> arr;
    string temp;
    s += delimiter;
    for (int i = 0; i < s.size(); i++) {
        if (s[i] != delimiter) {
            temp += s[i];
        }
        else{
            arr.push_back(temp);
            temp = "";
        }
    }
    
    for (int i = 0; i < arr.size(); i++) {
        cout << arr[i] << endl;
    }
    return arr;
}

int main() {
    string line;
    char del;
    cin >> line >> del;
    Split(line, del);
}
