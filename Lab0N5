#include <iostream>
#include <string>
#include <vector>

using namespace std;

string Join(vector <string> tokens, char delimiter) {
    vector <string> supp;
    string temp;
    temp += delimiter;

    for (int i = 0; i < tokens.size(); i++) {
        supp.push_back(tokens[i]);
        supp.push_back(temp);
    }

    temp = "";

    for (int i = 0; i < supp.size() - 1; i++) {
        temp += supp[i];
    }

    cout << temp;
    return temp;
}

int main() {
    vector <string> new_line;
    char del;
    string temp;
    int n;

    cout << "Enter amount of words: ";
    cin >> n;

    for (int i = 0; i < n; i ++) {
        cin >> temp;
        new_line.push_back(temp);
    }

    cin >> del;
    Join(new_line, del);
}
